.section-card {
  padding: 24rpx;
  border-radius: 28rpx;
}

.section-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.section-card__subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.section-card__body {
  margin-top: 18rpx;
}
