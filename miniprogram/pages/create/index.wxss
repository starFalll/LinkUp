.login-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
}

.login-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.login-card__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--ink-700);
}

.login-card__button {
  margin-top: 24rpx;
}

.login-card__status {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--accent);
}

.create-form {
  margin-top: 24rpx;
  padding: 28rpx 24rpx 32rpx;
}

.form-block + .form-block,
.form-grid,
.primary-button {
  margin-top: 26rpx;
}

.form-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-900);
}

.form-input,
.form-textarea,
.form-picker {
  display: block;
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: rgba(255, 248, 242, 0.98);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.form-input,
.form-picker {
  height: 92rpx;
  line-height: 92rpx;
  padding: 0 24rpx;
}

.form-textarea {
  min-height: 260rpx;
  padding: 24rpx;
}

.form-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.building-list {
  max-height: 280rpx;
  margin-top: 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 241, 0.95);
}

.building-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(203, 175, 155, 0.22);
  font-size: 26rpx;
}

.building-item:last-child {
  border-bottom: none;
}

.building-item--active {
  color: var(--accent);
  font-weight: 700;
}

.building-alias {
  font-size: 22rpx;
  color: var(--ink-500);
}

.selected-chip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--accent);
}

.form-grid {
  display: flex;
  gap: 18rpx;
}

.form-grid__item {
  flex: 1;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 244, 234, 0.94);
  font-size: 26rpx;
}
