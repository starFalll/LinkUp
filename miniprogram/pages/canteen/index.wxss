.canteen-hero {
  padding: 14rpx 6rpx 26rpx;
}

.canteen-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.canteen-card {
  padding: 28rpx 24rpx;
}

.canteen-card__header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.canteen-card__intro {
  flex: 1;
}

.canteen-card__badge {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--accent);
  background: rgba(243, 214, 200, 0.58);
}

.canteen-card__name {
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
}

.canteen-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--ink-700);
}

.canteen-score {
  min-width: 164rpx;
  text-align: right;
}

.canteen-score__value {
  font-size: 60rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--ink-900);
}

.canteen-score__stars {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.canteen-score__count {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.canteen-card__description {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--ink-900);
}

.canteen-card__metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.canteen-metric {
  flex: 1;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 244, 234, 0.94);
}

.canteen-metric__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--ink-700);
}

.canteen-metric__stars {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.canteen-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
}

.canteen-card__dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.canteen-card__dish {
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.canteen-card__link {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
}
