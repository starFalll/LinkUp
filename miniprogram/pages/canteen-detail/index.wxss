.canteen-detail {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.canteen-hero-card,
.review-editor,
.review-section {
  padding: 28rpx 24rpx;
}

.canteen-hero-card__top {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
}

.canteen-hero-card__intro {
  flex: 1;
}

.canteen-hero-card__name {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.canteen-hero-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--ink-700);
}

.canteen-overall {
  min-width: 180rpx;
  text-align: right;
}

.canteen-overall__value {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
}

.canteen-overall__stars {
  margin-top: 10rpx;
  font-size: 26rpx;
}

.canteen-overall__count {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.canteen-hero-card__description {
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.65;
  color: var(--ink-900);
}

.canteen-hero-card__dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.canteen-hero-card__dish {
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.canteen-hero-card__metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-metric {
  flex: 1;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 244, 234, 0.94);
}

.detail-metric__label {
  font-size: 22rpx;
  color: var(--ink-700);
}

.detail-metric__value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.detail-metric__stars {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.detail-section__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.review-editor__subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ink-700);
}

.review-editor__overall {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 244, 234, 0.94);
}

.review-editor__overall-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.review-editor__overall-stars {
  font-size: 26rpx;
}

.score-row {
  margin-top: 24rpx;
}

.score-row__header {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  font-weight: 600;
}

.score-row__stars {
  display: flex;
  gap: 18rpx;
  margin-top: 14rpx;
}

.score-row__star {
  font-size: 40rpx;
  line-height: 1;
  color: rgba(217, 164, 65, 0.28);
}

.score-row__star--active {
  color: var(--gold);
}

.review-editor__textarea {
  width: 100%;
  min-height: 240rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 248, 242, 0.98);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.review-editor__submit {
  margin-top: 28rpx;
}

.review-section__empty {
  margin-top: 20rpx;
}

.review-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(203, 175, 155, 0.22);
}

.review-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.review-card__user {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.review-card__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f2dfd2;
}

.review-card__avatar--fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a4d34;
  font-size: 30rpx;
  font-weight: 700;
}

.review-card__name {
  font-size: 28rpx;
  font-weight: 600;
}

.review-card__time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.review-card__overall {
  text-align: right;
}

.review-card__overall-value {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.review-card__overall-stars {
  margin-top: 8rpx;
  font-size: 20rpx;
}

.review-card__content {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--ink-900);
}

.review-card__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-card__badge {
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.review-card__actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.review-card__like {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--ink-700);
  background: rgba(255, 244, 234, 0.92);
}

.review-card__like--active {
  color: #fff;
  background: linear-gradient(135deg, #d4663b 0%, #bf5a2f 100%);
}

.review-card__delete {
  min-width: 124rpx;
  height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  color: var(--danger);
  background: rgba(188, 95, 79, 0.12);
}
