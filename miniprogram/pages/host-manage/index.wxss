.host-panel {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
}

.host-panel__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.request-row,
.post-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(203, 175, 155, 0.22);
}

.request-row:last-child,
.post-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.request-row__copy {
  margin-bottom: 18rpx;
}

.request-row__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-900);
}

.request-row__subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.request-row__actions {
  display: flex;
  gap: 14rpx;
}

.request-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.request-btn--primary {
  background: linear-gradient(135deg, #d4663b 0%, #bf5a2f 100%);
  color: #fff;
}

.request-btn--ghost {
  background: rgba(255, 244, 234, 0.95);
  color: var(--ink-900);
}

.request-btn--danger {
  background: rgba(188, 95, 79, 0.12);
  color: var(--danger);
}

.post-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.post-row__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.post-row__seat {
  font-size: 22rpx;
  color: var(--accent);
}

.post-row__delete {
  width: 144rpx;
  flex: none;
}
