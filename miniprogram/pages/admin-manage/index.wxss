.admin-panel {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
}

.admin-panel__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink-900);
}

.admin-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(203, 175, 155, 0.22);
}

.admin-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.admin-row__copy {
  flex: 1;
  min-width: 0;
}

.admin-row__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-900);
}

.admin-row__subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-700);
}

.admin-row__content {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--ink-900);
}

.admin-row__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
  flex: none;
}

.admin-row__danger {
  min-width: 156rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  line-height: 68rpx;
  font-size: 24rpx;
  color: var(--danger);
  background: rgba(188, 95, 79, 0.12);
}
